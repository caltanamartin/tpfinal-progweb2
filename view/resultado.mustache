{{>header}}
<div class="min-h-screen flex flex-col pt-14">
    <div class="flex-1 flex items-center justify-center p-4">
        <div class="w-full max-w-lg text-center">

            {{#huboError}}
            <div class="mb-6">
                <div class="w-20 h-20 mx-auto rounded-full bg-red-100 flex items-center justify-center mb-4">
                    <svg class="w-10 h-10 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </div>
                <h1 class="text-3xl font-bold text-gray-800 mb-2">¡Respuesta incorrecta!</h1>
                <p class="text-gray-500">Respondiste mal. Sumaste <strong class="text-[#00b582]">{{partida.puntaje}}</strong> punto(s).</p>
            </div>
            {{/huboError}}
            {{^huboError}}
            <div class="mb-6">
                <div class="w-20 h-20 mx-auto rounded-full bg-green-100 flex items-center justify-center mb-4">
                    <svg class="w-10 h-10 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M5 13l4 4L19 7"/>
                    </svg>
                </div>
                <h1 class="text-3xl font-bold text-gray-800 mb-2">¡No hay más preguntas!</h1>
                <p class="text-gray-500">Respondiste todas las preguntas disponibles. Sumaste <strong class="text-[#00b582]">{{partida.puntaje}}</strong> punto(s).</p>
            </div>
            {{/huboError}}

            {{#ultimaPregunta}}
            <div class="bg-white rounded-2xl shadow-lg p-6 mb-6 text-left">
                <p class="text-sm font-medium text-gray-500 mb-2">Última pregunta:</p>
                <p class="text-gray-800 font-semibold mb-3">{{ultimaPregunta.pregunta}}</p>
                <div class="space-y-1.5">
                    <p class="text-sm {{#huboError}}text-red-600 font-medium{{/huboError}}">
                        A: {{ultimaPregunta.opciones.A}}
                    </p>
                    <p class="text-sm {{#huboError}}text-red-600 font-medium{{/huboError}}">
                        B: {{ultimaPregunta.opciones.B}}
                    </p>
                    <p class="text-sm {{#huboError}}text-red-600 font-medium{{/huboError}}">
                        C: {{ultimaPregunta.opciones.C}}
                    </p>
                    <p class="text-sm {{#huboError}}text-red-600 font-medium{{/huboError}}">
                        D: {{ultimaPregunta.opciones.D}}
                    </p>
                </div>
                {{#huboError}}
                <div class="mt-4 p-3 bg-green-50 border border-green-200 rounded-xl">
                    <p class="text-sm text-green-800">
                        <span class="font-bold">Respuesta correcta:</span> {{ultimaPregunta.respuesta_correcta}}
                    </p>
                </div>
                {{/huboError}}
            </div>
            {{/ultimaPregunta}}

            <div class="flex gap-3 justify-center">
                <a href="/"
                   class="px-6 py-3 rounded-xl border-2 border-gray-300 text-gray-600 font-medium
                          hover:bg-gray-100 transition-all duration-200 cursor-pointer">
                    Volver al lobby
                </a>
                <a href="/juego/nueva"
                   class="px-6 py-3 rounded-xl bg-[#00b582] text-white font-semibold
                          hover:bg-[#009a6e] transition-all duration-200 cursor-pointer shadow-md">
                    Jugar de nuevo
                </a>
            </div>
        </div>
    </div>
    {{>footer}}
</div>
