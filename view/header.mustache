<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PreguntaTres</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        input:focus { border-color: #007ca6 !important; box-shadow: 0 0 0 3px rgba(0,124,166,0.15) !important; outline: none !important; }
    </style>
</head>
<body class="bg-gray-50 text-gray-900 antialiased m-0">
<audio id="bgm" src="/audio/music.mp3" loop preload="auto"></audio>

<header class="fixed top-0 left-0 w-full z-50 bg-white border-b border-gray-200">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="flex items-center justify-between h-14">
            <a href="/" class="text-xl font-bold text-[#272727]">PreguntaTres</a>
            
            <div class="flex items-center gap-4">
                {{#usuario}}
                <a href="/" class="text-sm font-medium text-gray-600 hover:text-[#00b582] transition-colors duration-200">Lobby</a>
                <a href="/trampitas" class="text-sm font-medium text-gray-600 hover:text-[#00b582] transition-colors duration-200">Tienda</a>
                <a href="/ranking" class="text-sm font-medium text-gray-600 hover:text-[#00b582] transition-colors duration-200">Ranking</a>
                <a href="/perfil" class="text-sm font-medium text-gray-600 hover:text-[#00b582] transition-colors duration-200">Mi perfil</a>
                {{#usuario.esEditor}}
                <a href="/editor" class="text-sm font-medium text-orange-600 hover:text-orange-700 transition-colors duration-200">Panel editor</a>
                {{/usuario.esEditor}}
                {{#usuario.esAdmin}}
                <a href="/admin" class="text-sm font-medium text-purple-600 hover:text-purple-700 transition-colors duration-200">Panel admin</a>
                {{/usuario.esAdmin}}
                <a href="/logout"
                   class="text-sm font-medium px-4 py-2 rounded-lg transition-all duration-200 cursor-pointer hover:opacity-70 text-[#272727]">
                    Cerrar sesión
                </a>
                {{/usuario}}
                {{^usuario}}
                <a
                    {{#esLogin}}href="/"{{/esLogin}}
                    {{#esRegistro}}href="/"{{/esRegistro}}
                    {{#esHome}}href="/login"{{/esHome}}
                    class="text-sm font-medium px-4 py-2 rounded-lg transition-all duration-200 cursor-pointer hover:opacity-70 text-[#272727]">
                    {{#esLogin}}Volver{{/esLogin}}
                    {{#esRegistro}}Volver{{/esRegistro}}
                    {{#esHome}}Iniciar sesión{{/esHome}}
                </a>
                {{/usuario}}
                <button id="btn-music" type="button"
                        class="text-gray-500 hover:text-[#00b582] transition-colors duration-200 cursor-pointer"
                        title="Activar / silenciar música">
                    <svg id="icon-music-on" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072M18.364 5.636a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"/>
                    </svg>
                    <svg id="icon-music-off" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2"/>
                    </svg>
                </button>
            </div>
        </div>
    </div>
</header>
