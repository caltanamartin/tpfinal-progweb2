{{>header}}
<div class="min-h-screen flex flex-col bg-gray-50 pt-16">
    <div class="flex-1 flex items-start justify-center px-4 py-8">
        <div class="w-full max-w-md">
            <div class="bg-white rounded-2xl p-8 border border-gray-200 shadow-sm">
                <div class="flex flex-col items-center mb-6">
                    {{#usuario.foto_perfil}}
                    <img src="/{{usuario.foto_perfil}}" alt="Foto de perfil"
                         class="w-24 h-24 rounded-full object-cover border-4 border-[#00b582] shadow-md mb-4">
                    {{/usuario.foto_perfil}}
                    {{^usuario.foto_perfil}}
                    <img src="/uploads/foto-default.svg" alt="Foto de perfil"
                         class="w-24 h-24 rounded-full border-4 border-gray-200 bg-gray-100 mb-4">
                    {{/usuario.foto_perfil}}
                    <h2 class="text-xl font-bold text-gray-800">{{usuario.username}}</h2>
                    <p class="text-sm text-gray-500">{{usuario.nombre}}</p>
                </div>

                <div class="border-t border-gray-100 pt-6 space-y-4">
                    {{#esPropio}}
                    <div>
                        <p class="text-xs uppercase tracking-wide text-gray-400 font-medium">Email</p>
                        <p class="text-sm text-gray-700">{{usuario.email}}</p>
                    </div>
                    {{/esPropio}}
                    <div>
                        <p class="text-xs uppercase tracking-wide text-gray-400 font-medium">Fecha de nacimiento</p>
                        <p class="text-sm text-gray-700">{{usuario.anio_nacimiento}}</p>
                    </div>
                    <div>
                        <p class="text-xs uppercase tracking-wide text-gray-400 font-medium">Sexo</p>
                        <p class="text-sm text-gray-700">{{usuario.sexo}}</p>
                    </div>
                    <div>
                        <p class="text-xs uppercase tracking-wide text-gray-400 font-medium">País</p>
                        <p class="text-sm text-gray-700">{{usuario.pais}}</p>
                    </div>
                    <div>
                        <p class="text-xs uppercase tracking-wide text-gray-400 font-medium">Ciudad</p>
                        <p class="text-sm text-gray-700">{{usuario.ciudad}}</p>
                    </div>
                </div>

                <div class="border-t border-gray-100 pt-6 mt-6 space-y-4">
                    <div class="flex justify-between items-center p-4 bg-gray-50 rounded-xl">
                        <span class="text-sm text-gray-600 font-medium">Puntaje total</span>
                        <span class="text-lg font-bold text-[#00b582]">{{usuario.puntaje_total}}</span>
                    </div>
                    <div class="flex justify-between items-center p-4 bg-gray-50 rounded-xl">
                        <span class="text-sm text-gray-600 font-medium">Partidas jugadas</span>
                        <span class="text-lg font-bold text-[#007ca6]">{{usuario.cantidad_partidas}}</span>
                    </div>
                </div>

                {{#usuario.pais}}
                <div class="border-t border-gray-100 pt-6 mt-6">
                    <p class="text-xs uppercase tracking-wide text-gray-400 font-medium mb-3">Ubicación</p>
                    <div id="mapa" class="w-full rounded-xl overflow-hidden border border-gray-200" style="height: 200px;"
                         data-label="{{usuario.ciudad}}, {{usuario.pais}}"></div>
                </div>
                {{/usuario.pais}}

                <div class="border-t border-gray-100 pt-6 mt-6">
                    {{#esPropio}}
                    <a href="/perfil/editar"
                       class="block text-center w-full bg-[#00b582] font-bold text-lg px-10 py-3 rounded-full text-white transition-all duration-300 cursor-pointer shadow-md hover:shadow-lg">
                        Editar perfil
                    </a>
                    {{/esPropio}}
                    {{^esPropio}}
                    <a href="/ranking" class="block text-center text-sm font-medium text-[#007ca6] hover:underline">Volver al ranking</a>
                    {{/esPropio}}
                </div>
            </div>
        </div>
    </div>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        var mapaDiv = document.getElementById('mapa');
        if (!mapaDiv) return;

        function initMap(lat, lng, label) {
            var map = L.map('mapa', { zoomControl: false }).setView([lat, lng], 6);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
            L.marker([lat, lng]).addTo(map).bindPopup(label);
        }

        var ubi = encodeURIComponent(mapaDiv.dataset.label);
        var xhr = new XMLHttpRequest();
        xhr.open('GET', 'https://nominatim.openstreetmap.org/search?q=' + ubi + '&format=json&limit=1', true);
        xhr.send();
        xhr.onload = function() {
            if (xhr.status === 200) {
                var data = JSON.parse(xhr.responseText);
                if (data.length > 0) {
                    initMap(parseFloat(data[0].lat), parseFloat(data[0].lon), mapaDiv.dataset.label);
                } else {
                    mapaDiv.innerHTML = '<p class="text-sm text-gray-400 text-center py-8">Ubicación no encontrada</p>';
                }
            }
        };
    });
    </script>
    {{>footer}}
</div>
