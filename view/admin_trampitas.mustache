{{>header}}
<div class="min-h-screen flex flex-col pt-14">
    <div class="flex-1 px-4 py-8 max-w-5xl mx-auto w-full">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
            <h1 class="text-2xl font-bold text-gray-800">Trampitas compradas</h1>
            <div class="flex items-center gap-2">
                <a href="/admin/trampitas" class="text-xs px-3 py-1.5 rounded-lg transition-colors {{#esFiltroTodas}}bg-purple-600 text-white{{/esFiltroTodas}}{{^esFiltroTodas}}bg-gray-200 text-gray-700 hover:bg-gray-300{{/esFiltroTodas}}">Todas</a>
                <a href="/admin/trampitas?tipo=50/50" class="text-xs px-3 py-1.5 rounded-lg transition-colors {{#esFiltro5050}}bg-purple-600 text-white{{/esFiltro5050}}{{^esFiltro5050}}bg-gray-200 text-gray-700 hover:bg-gray-300{{/esFiltro5050}}">50/50</a>
                <a href="/admin/trampitas?tipo=skip" class="text-xs px-3 py-1.5 rounded-lg transition-colors {{#esFiltroSkip}}bg-purple-600 text-white{{/esFiltroSkip}}{{^esFiltroSkip}}bg-gray-200 text-gray-700 hover:bg-gray-300{{/esFiltroSkip}}">Skip</a>
                <a href="/admin/trampitas?tipo=congelar_tiempo" class="text-xs px-3 py-1.5 rounded-lg transition-colors {{#esFiltroFreeze}}bg-purple-600 text-white{{/esFiltroFreeze}}{{^esFiltroFreeze}}bg-gray-200 text-gray-700 hover:bg-gray-300{{/esFiltroFreeze}}">Congelar tiempo</a>
            </div>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
            <div class="bg-white rounded-2xl p-4 border border-gray-200 shadow-sm">
                <p class="text-sm text-gray-500 mb-1">Compras totales</p>
                <p class="text-3xl font-bold text-gray-800">{{estadisticas.totalCompras}}</p>
            </div>
            <div class="bg-white rounded-2xl p-4 border border-gray-200 shadow-sm">
                <p class="text-sm text-gray-500 mb-1">Recaudación total</p>
                <p class="text-3xl font-bold text-[#00b582]">USD {{estadisticas.totalRecaudado}},00</p>
            </div>
            {{#estadisticas.porTipo}}
            <div class="bg-white rounded-2xl p-4 border border-gray-200 shadow-sm">
                <p class="text-sm text-gray-500 mb-1">{{#es5050}}<i class="fas fa-bomb mr-1"></i>{{/es5050}}{{#esSkip}}<i class="fas fa-forward-step mr-1"></i>{{/esSkip}}{{#esFreeze}}<i class="fas fa-snowflake mr-1"></i>{{/esFreeze}}{{nombre}}</p>
                <p class="text-xl font-bold text-gray-800">{{cantidad}} <span class="text-sm text-gray-400 font-normal">(USD {{recaudado}},00)</span></p>
            </div>
            {{/estadisticas.porTipo}}
        </div>

        <p class="text-sm text-gray-500 mb-4">Total: {{total}} compras</p>

        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="bg-gray-50 text-left">
                            <th class="px-4 py-3 font-semibold text-gray-600">ID</th>
                            <th class="px-4 py-3 font-semibold text-gray-600">Usuario</th>
                            <th class="px-4 py-3 font-semibold text-gray-600">Tipo</th>
                            <th class="px-4 py-3 font-semibold text-gray-600">Estado</th>
                            <th class="px-4 py-3 font-semibold text-gray-600">Comprada</th>
                            <th class="px-4 py-3 font-semibold text-gray-600">Usada</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#trampitas}}
                        <tr class="border-t border-gray-100 hover:bg-gray-50">
                            <td class="px-4 py-3 font-mono text-xs">{{id}}</td>
                            <td class="px-4 py-3">
                                <span class="font-medium">{{usuario_nombre}}</span>
                                <span class="text-gray-400 text-xs">@{{username}}</span>
                            </td>
                            <td class="px-4 py-3">
                                {{#es5050}}<span class="inline-block text-xs px-2 py-0.5 rounded-full bg-blue-100 text-blue-700">50/50</span>{{/es5050}}
                                {{#esSkip}}<span class="inline-block text-xs px-2 py-0.5 rounded-full bg-yellow-100 text-yellow-700">Skip</span>{{/esSkip}}
                                {{#esFreeze}}<span class="inline-block text-xs px-2 py-0.5 rounded-full bg-cyan-100 text-cyan-700">Congelar tiempo</span>{{/esFreeze}}
                            </td>
                            <td class="px-4 py-3">
                                {{#esDisponible}}<span class="text-green-600 font-medium">Disponible</span>{{/esDisponible}}
                                {{#esUsado}}<span class="text-gray-400">Usado</span>{{/esUsado}}
                            </td>
                            <td class="px-4 py-3 text-gray-500 text-xs">{{comprada_en}}</td>
                            <td class="px-4 py-3 text-gray-500 text-xs">{{usada_en}}</td>
                        </tr>
                        {{/trampitas}}
                        {{^trampitas}}
                        <tr><td colspan="6" class="px-4 py-8 text-center text-gray-400">No hay trampitas compradas</td></tr>
                        {{/trampitas}}
                    </tbody>
                </table>
            </div>
        </div>

        {{#totalPaginas}}
        <div class="flex justify-center gap-2 mt-6">
            {{#page_prev}}
            <a href="/admin/trampitas?page={{page_prev}}{{#tipoFiltro}}&tipo={{tipoFiltro}}{{/tipoFiltro}}" class="px-3 py-1.5 rounded-lg bg-gray-200 text-gray-700 hover:bg-gray-300 transition-colors text-sm">&larr; Anterior</a>
            {{/page_prev}}
            {{#page_next}}
            <a href="/admin/trampitas?page={{page_next}}{{#tipoFiltro}}&tipo={{tipoFiltro}}{{/tipoFiltro}}" class="px-3 py-1.5 rounded-lg bg-gray-200 text-gray-700 hover:bg-gray-300 transition-colors text-sm">Siguiente &rarr;</a>
            {{/page_next}}
        </div>
        {{/totalPaginas}}

        <div class="mt-8 text-center">
            <a href="/admin" class="text-sm text-gray-400 hover:text-gray-600 transition-colors">Volver al panel admin</a>
        </div>
    </div>
    {{>footer}}
</div>
