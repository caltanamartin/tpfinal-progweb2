{{>header}}
<div class="min-h-screen flex flex-col bg-gray-50 pt-16">
    <div class="flex-1 max-w-3xl mx-auto w-full px-4 sm:px-6 py-8">
        <h2 class="text-2xl font-bold text-gray-800 mb-6">Ranking de jugadores</h2>

        {{^usuarios}}
        <p class="text-gray-400 text-center py-12">Todavía no hay partidas terminadas.</p>
        {{/usuarios}}

        {{#usuarios}}
        <a href="/perfil?id={{id}}" class="flex items-center gap-4 bg-white rounded-xl px-5 py-4 mb-3 border border-gray-200 shadow-sm hover:border-[#00b582] hover:shadow-md transition-all duration-200">
            <span class="text-lg font-bold text-gray-400 w-8 text-center">{{posicion}}</span>
            <div class="w-10 h-10 rounded-full bg-gray-100 overflow-hidden flex-shrink-0 border-2 border-gray-200">
                {{#foto_perfil}}
                <img src="/{{foto_perfil}}" alt="{{nombre}}" class="w-full h-full object-cover">
                {{/foto_perfil}}
                {{^foto_perfil}}
                <img src="/uploads/foto-default.svg" alt="Sin foto" class="w-full h-full object-cover p-2">
                {{/foto_perfil}}
            </div>
            <div class="flex-1 min-w-0">
                <p class="font-semibold text-gray-800 truncate">{{#esPrimero}}<i class="fas fa-crown text-yellow-500 mr-1"></i>{{/esPrimero}}{{nombre}}</p>
                <p class="text-sm text-gray-400">{{username}}</p>
            </div>
            <div class="text-right flex-shrink-0">
                <p class="font-bold text-lg text-[#00b582]">{{puntaje_total}} pts</p>
                <p class="text-xs text-gray-400">{{cantidad_partidas}} partidas</p>
            </div>
        </a>
        {{/usuarios}}

        {{#usuario}}
        <div class="mt-8 text-center">
            <a href="/" class="text-sm font-medium text-[#007ca6] hover:underline">Volver al lobby</a>
        </div>
        {{/usuario}}
    </div>
</div>
{{>footer}}
