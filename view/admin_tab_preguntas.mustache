{{! ============ TAB PREGUNTAS ============ }}
<div id="tab-preguntas" class="tab-content hidden">
    {{#exito}}
    <p class="text-sm text-green-600 bg-green-50 border border-green-200 rounded-xl px-4 py-3 mb-4">{{exito}}</p>
    {{/exito}}
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden mb-6">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-gray-50 text-gray-500 uppercase text-xs tracking-wide">
                        <th class="text-left px-4 py-3">ID</th>
                        <th class="text-left px-4 py-3">Categoría</th>
                        <th class="text-left px-4 py-3">Pregunta</th>
                        <th class="text-left px-4 py-3">Activa</th>
                        <th class="text-left px-4 py-3">Creador</th>
                        <th class="text-right px-4 py-3">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {{#todasPreguntas}}
                    <tr class="border-t border-gray-100 hover:bg-gray-50 transition-colors">
                        <td class="px-4 py-3 text-gray-600">{{id}}</td>
                        <td class="px-4 py-3">
                            <span class="text-xs px-2 py-0.5 rounded-full text-white" style="background: {{categoria_color}};">
                                {{categoria_nombre}}
                            </span>
                        </td>
                        <td class="px-4 py-3 text-gray-800 max-w-xs truncate">{{pregunta}}</td>
                        <td class="px-4 py-3">
                            {{#activa}}
                            <span class="text-xs px-2 py-0.5 rounded-full bg-green-100 text-green-700">Sí</span>
                            {{/activa}}
                            {{^activa}}
                            <span class="text-xs px-2 py-0.5 rounded-full bg-red-100 text-red-700">No</span>
                            {{/activa}}
                        </td>
                        <td class="px-4 py-3 text-gray-500">{{creador_username}}</td>
                        <td class="px-4 py-3 text-right">
                            <div class="flex gap-2 justify-end">
                                <button type="button" onclick="document.getElementById('modal-preg-{{id}}').classList.remove('hidden')"
                                        class="text-xs px-3 py-1.5 rounded-lg bg-gray-50 text-gray-600 hover:bg-gray-100 transition-colors cursor-pointer">
                                    Ver
                                </button>
                                <a href="/editor/preguntas/editar/{{id}}"
                                   class="text-xs px-3 py-1.5 rounded-lg bg-blue-50 text-blue-600 hover:bg-blue-100 transition-colors">
                                    Editar
                                </a>
                                {{#activa}}
                                <form action="/editor/preguntas/eliminar" method="POST" onsubmit="return confirm('¿Desactivar esta pregunta?')">
                                    <input type="hidden" name="id" value="{{id}}">
                                    <button type="submit"
                                            class="text-xs px-3 py-1.5 rounded-lg bg-red-50 text-red-600 hover:bg-red-100 transition-colors cursor-pointer">
                                        Desactivar
                                    </button>
                                </form>
                                {{/activa}}
                                {{^activa}}
                                <form action="/editor/preguntas/activar" method="POST">
                                    <input type="hidden" name="id" value="{{id}}">
                                    <button type="submit"
                                            class="text-xs px-3 py-1.5 rounded-lg bg-yellow-50 text-yellow-700 hover:bg-yellow-100 transition-colors cursor-pointer">
                                        Activar
                                    </button>
                                </form>
                                {{/activa}}
                            </div>
                        </td>
                    </tr>

                    <div id="modal-preg-{{id}}" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40">
                        <div class="bg-white rounded-2xl shadow-xl p-6 w-full max-w-lg mx-4 max-h-[80vh] overflow-y-auto">
                            <div class="flex items-center justify-between mb-4">
                                <h3 class="text-lg font-bold text-gray-800">Detalle de pregunta</h3>
                                <button type="button" onclick="document.getElementById('modal-preg-{{id}}').classList.add('hidden')"
                                        class="text-gray-400 hover:text-gray-600 text-xl leading-none cursor-pointer">&times;</button>
                            </div>
                            <p class="text-xs text-gray-400 mb-1">ID: {{id}}</p>
                            <p class="text-gray-800 font-semibold mb-4">{{pregunta}}</p>
                            <div class="space-y-2">
                                <div class="px-4 py-3 rounded-xl border-2 {{#esCorrectaA}}border-green-400 bg-green-50{{/esCorrectaA}}{{^esCorrectaA}}border-gray-200{{/esCorrectaA}} flex items-center gap-3">
                                    <span class="w-7 h-7 rounded-full bg-gray-100 flex items-center justify-center font-bold text-xs text-gray-500 flex-shrink-0">A</span>
                                    <span class="text-gray-700">{{opcion_a}}</span>
                                    {{#esCorrectaA}}<span class="ml-auto text-xs font-semibold text-green-600">Correcta</span>{{/esCorrectaA}}
                                </div>
                                <div class="px-4 py-3 rounded-xl border-2 {{#esCorrectaB}}border-green-400 bg-green-50{{/esCorrectaB}}{{^esCorrectaB}}border-gray-200{{/esCorrectaB}} flex items-center gap-3">
                                    <span class="w-7 h-7 rounded-full bg-gray-100 flex items-center justify-center font-bold text-xs text-gray-500 flex-shrink-0">B</span>
                                    <span class="text-gray-700">{{opcion_b}}</span>
                                    {{#esCorrectaB}}<span class="ml-auto text-xs font-semibold text-green-600">Correcta</span>{{/esCorrectaB}}
                                </div>
                                <div class="px-4 py-3 rounded-xl border-2 {{#esCorrectaC}}border-green-400 bg-green-50{{/esCorrectaC}}{{^esCorrectaC}}border-gray-200{{/esCorrectaC}} flex items-center gap-3">
                                    <span class="w-7 h-7 rounded-full bg-gray-100 flex items-center justify-center font-bold text-xs text-gray-500 flex-shrink-0">C</span>
                                    <span class="text-gray-700">{{opcion_c}}</span>
                                    {{#esCorrectaC}}<span class="ml-auto text-xs font-semibold text-green-600">Correcta</span>{{/esCorrectaC}}
                                </div>
                                <div class="px-4 py-3 rounded-xl border-2 {{#esCorrectaD}}border-green-400 bg-green-50{{/esCorrectaD}}{{^esCorrectaD}}border-gray-200{{/esCorrectaD}} flex items-center gap-3">
                                    <span class="w-7 h-7 rounded-full bg-gray-100 flex items-center justify-center font-bold text-xs text-gray-500 flex-shrink-0">D</span>
                                    <span class="text-gray-700">{{opcion_d}}</span>
                                    {{#esCorrectaD}}<span class="ml-auto text-xs font-semibold text-green-600">Correcta</span>{{/esCorrectaD}}
                                </div>
                            </div>
                            <div class="mt-6 text-center">
                                <button type="button" onclick="document.getElementById('modal-preg-{{id}}').classList.add('hidden')"
                                        class="px-6 py-2 rounded-xl border-2 border-gray-300 text-gray-600 font-medium hover:bg-gray-100 transition-all duration-200 cursor-pointer">
                                    Cerrar
                                </button>
                            </div>
                        </div>
                    </div>
                    {{/todasPreguntas}}
                    {{^todasPreguntas}}
                    <tr>
                        <td colspan="6" class="px-4 py-8 text-center text-gray-400">No hay preguntas.</td>
                    </tr>
                    {{/todasPreguntas}}
                </tbody>
            </table>
        </div>
    </div>
</div>
