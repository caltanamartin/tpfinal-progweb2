{{! ============ TAB PARTIDAS ============ }}
<div id="tab-partidas" class="tab-content hidden">
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-4 sm:p-6 mb-6">
        <div id="chart-line-partidas" style="height: 280px;"></div>
    </div>
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden mb-6">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-gray-50 text-gray-500 uppercase text-xs tracking-wide">
                        <th class="text-left px-4 py-3">ID</th>
                        <th class="text-left px-4 py-3">Usuario</th>
                        <th class="text-left px-4 py-3">Puntaje</th>
                        <th class="text-left px-4 py-3">Preguntas</th>
                        <th class="text-left px-4 py-3">Correctas</th>
                        <th class="text-left px-4 py-3">Estado</th>
                        <th class="text-right px-4 py-3">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {{#todasPartidas}}
                    <tr class="border-t border-gray-100 hover:bg-gray-50 transition-colors">
                        <td class="px-4 py-3 text-gray-600">{{id}}</td>
                        <td class="px-4 py-3 font-medium text-gray-800">{{username}}</td>
                        <td class="px-4 py-3 text-gray-800">{{puntaje}}</td>
                        <td class="px-4 py-3 text-gray-500">{{total_preguntas}}</td>
                        <td class="px-4 py-3 text-gray-500">{{respuestas_correctas}}</td>
                        <td class="px-4 py-3">
                            {{#jugando}}<span class="text-xs px-2 py-0.5 rounded-full bg-yellow-100 text-yellow-700">Jugando</span>{{/jugando}}
                            {{#terminada}}<span class="text-xs px-2 py-0.5 rounded-full bg-green-100 text-green-700">Terminada</span>{{/terminada}}
                        </td>
                        <td class="px-4 py-3 text-right">
                            <button type="button" onclick="document.getElementById('modal-partida-{{id}}').classList.remove('hidden')"
                                    class="text-xs px-3 py-1.5 rounded-lg bg-gray-50 text-gray-600 hover:bg-gray-100 transition-colors cursor-pointer">
                                Ver
                            </button>
                        </td>
                    </tr>

                    <div id="modal-partida-{{id}}" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40">
                        <div class="bg-white rounded-2xl shadow-xl p-6 w-full max-w-lg mx-4">
                            <div class="flex items-center justify-between mb-4">
                                <h3 class="text-lg font-bold text-gray-800">Detalle de partida</h3>
                                <button type="button" onclick="document.getElementById('modal-partida-{{id}}').classList.add('hidden')"
                                        class="text-gray-400 hover:text-gray-600 text-xl leading-none cursor-pointer">&times;</button>
                            </div>
                            <dl class="space-y-3 text-sm">
                                <div class="flex justify-between border-b border-gray-100 pb-2">
                                    <dt class="text-gray-500">ID</dt>
                                    <dd class="text-gray-800 font-medium">{{id}}</dd>
                                </div>
                                <div class="flex justify-between border-b border-gray-100 pb-2">
                                    <dt class="text-gray-500">Usuario</dt>
                                    <dd class="text-gray-800 font-medium">{{username}}</dd>
                                </div>
                                <div class="flex justify-between border-b border-gray-100 pb-2">
                                    <dt class="text-gray-500">Puntaje</dt>
                                    <dd class="text-gray-800">{{puntaje}}</dd>
                                </div>
                                <div class="flex justify-between border-b border-gray-100 pb-2">
                                    <dt class="text-gray-500">Preguntas respondidas</dt>
                                    <dd class="text-gray-800">{{total_preguntas}}</dd>
                                </div>
                                <div class="flex justify-between border-b border-gray-100 pb-2">
                                    <dt class="text-gray-500">Respuestas correctas</dt>
                                    <dd class="text-gray-800">{{respuestas_correctas}}</dd>
                                </div>
                                <div class="flex justify-between border-b border-gray-100 pb-2">
                                    <dt class="text-gray-500">Estado</dt>
                                    <dd class="text-gray-800 capitalize">{{estado}}</dd>
                                </div>
                                <div class="flex justify-between border-b border-gray-100 pb-2">
                                    <dt class="text-gray-500">Creado</dt>
                                    <dd class="text-gray-800">{{creado_en}}</dd>
                                </div>
                                <div class="flex justify-between pb-2">
                                    <dt class="text-gray-500">Terminada</dt>
                                    <dd class="text-gray-800">{{terminada_en}}</dd>
                                </div>
                            </dl>
                            <div class="mt-6 text-center">
                                <button type="button" onclick="document.getElementById('modal-partida-{{id}}').classList.add('hidden')"
                                        class="px-6 py-2 rounded-xl border-2 border-gray-300 text-gray-600 font-medium hover:bg-gray-100 transition-all duration-200 cursor-pointer">
                                    Cerrar
                                </button>
                            </div>
                        </div>
                    </div>
                    {{/todasPartidas}}
                    {{^todasPartidas}}
                    <tr>
                        <td colspan="7" class="px-4 py-8 text-center text-gray-400">No hay partidas.</td>
                    </tr>
                    {{/todasPartidas}}
                </tbody>
            </table>
        </div>
    </div>
    {{#pagPartidas.mostrar}}
    <div class="flex items-center justify-center gap-1 mt-4 mb-6">
        {{#pagPartidas.anterior}}
        <a href="?{{pagPartidas.param}}={{pagPartidas.prevPage}}{{#pagPartidas.hash}}#{{pagPartidas.hash}}{{/pagPartidas.hash}}"
           class="px-3 py-1.5 text-sm rounded-lg bg-gray-200 text-gray-700 hover:bg-gray-300 transition-colors">Anterior</a>
        {{/pagPartidas.anterior}}
        {{#pagPartidas.numeros}}
        <a href="?{{pagPartidas.param}}={{num}}{{#pagPartidas.hash}}#{{pagPartidas.hash}}{{/pagPartidas.hash}}"
           class="px-3 py-1.5 text-sm rounded-lg transition-colors {{#activa}}bg-purple-600 text-white{{/activa}}{{^activa}}bg-gray-200 text-gray-700 hover:bg-gray-300{{/activa}}">{{num}}</a>
        {{/pagPartidas.numeros}}
        {{#pagPartidas.siguiente}}
        <a href="?{{pagPartidas.param}}={{pagPartidas.nextPage}}{{#pagPartidas.hash}}#{{pagPartidas.hash}}{{/pagPartidas.hash}}"
           class="px-3 py-1.5 text-sm rounded-lg bg-gray-200 text-gray-700 hover:bg-gray-300 transition-colors">Siguiente</a>
        {{/pagPartidas.siguiente}}
    </div>
    {{/pagPartidas.mostrar}}
</div>
