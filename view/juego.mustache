{{>header}}
<div class="min-h-screen flex flex-col pt-14">
    <div class="flex-1 flex items-center justify-center p-4">
        <div class="w-full max-w-lg">
            <div class="flex justify-between items-center mb-4">
                <span id="timer" class="text-lg font-bold text-gray-600 flex items-center gap-1">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <span id="timer-segundos">{{tiempo_restante}}</span>s
                </span>
                <span class="text-lg font-bold text-[#00b582]">
                    Puntaje: {{partida.puntaje}}
                </span>
            </div>

            <div class="rounded-2xl shadow-lg overflow-hidden"
                 style="border-top: 6px solid {{pregunta.categoria_color}};">

                {{#exito}}
                <div class="bg-green-50 border border-green-200 px-6 py-3 text-sm text-green-700 text-center">{{exito}}</div>
                {{/exito}}
                <div class="bg-white px-6 py-3 flex items-center gap-2"
                     style="background-color: {{pregunta.categoria_color}}10;">
                    <span class="text-xs font-semibold uppercase tracking-wide"
                          style="color: {{pregunta.categoria_color}};">
                        {{pregunta.categoria_nombre}}
                    </span>
                    {{#pregunta.esNeutra}}
                    <span class="text-xs px-2 py-0.5 rounded-full bg-gray-200 text-gray-500">Periodo de prueba{{#pregunta.respuestas_global}} ({{pregunta.respuestas_global}}/10){{/pregunta.respuestas_global}}</span>
                    {{/pregunta.esNeutra}}
                    {{^pregunta.esNeutra}}
                    <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 text-gray-600">{{pregunta.dificultad_label}}</span>
                    {{/pregunta.esNeutra}}

                    <button type="button" onclick="document.getElementById('report-modal').classList.remove('hidden')"
                            class="ml-auto text-xs text-gray-400 hover:text-red-500 transition-colors duration-200 cursor-pointer">
                        Reportar
                    </button>
                </div>

                <div class="bg-white px-6 py-6">
                    <h2 class="text-xl font-bold text-gray-800 mb-6 leading-relaxed">
                        {{pregunta.pregunta}}
                    </h2>

                    <form action="/juego/responder" method="POST" id="form-respuesta">
                        <input type="hidden" name="partida_id" value="{{partida.id}}">
                        <div class="space-y-3">
                            {{#pregunta.opciones}}
                            <button type="submit" name="respuesta" value="{{letra}}"
                                    class="w-full text-left px-5 py-4 rounded-xl border-2 border-gray-200
                                           hover:border-[#00b582] hover:bg-[#00b582] hover:text-white
                                           hover:shadow-md transition-all duration-200
                                           font-medium text-gray-700 cursor-pointer flex items-center gap-3
                                           focus:outline-none focus:ring-2 focus:ring-[#00b582] focus:ring-offset-2
                                           {{#oculta}}hidden{{/oculta}}">
                                <span class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center
                                             font-bold text-sm text-gray-500 flex-shrink-0
                                             group-hover:bg-white/20 group-hover:text-white">
                                    {{letra}}
                                </span>
                                <span>{{texto}}</span>
                            </button>
                            {{/pregunta.opciones}}
                        </div>
                    </form>
                    {{#stockTrampitas}}
                    <div class="border-t border-gray-100 px-6 py-3">
                        <div class="flex gap-2">
                            <form action="/trampitas/usar" method="POST" class="flex-1 min-w-0">
                                <input type="hidden" name="partida_id" value="{{partida.id}}">
                                <input type="hidden" name="tipo" value="50/50">
                                <button type="submit" onclick="return {{c_5050}} > 0;"
                                        class="w-full px-2 py-2 rounded-xl border-2 text-center transition-all duration-200
                                               {{#c_5050}}border-blue-200 bg-blue-50 hover:bg-blue-100 hover:border-blue-400 cursor-pointer{{/c_5050}}
                                               {{^c_5050}}border-gray-200 bg-gray-50 opacity-50 cursor-not-allowed{{/c_5050}}">
                                    <span class="block text-xs font-bold {{#c_5050}}text-blue-700{{/c_5050}}{{^c_5050}}text-gray-400{{/c_5050}}"><i class="fas fa-bomb"></i> 50/50</span>
                                    <span class="block text-[10px] {{#c_5050}}text-blue-500{{/c_5050}}{{^c_5050}}text-gray-400{{/c_5050}}">({{c_5050}})</span>
                                </button>
                            </form>
                            <form action="/trampitas/usar" method="POST" class="flex-1 min-w-0">
                                <input type="hidden" name="partida_id" value="{{partida.id}}">
                                <input type="hidden" name="tipo" value="skip">
                                <button type="submit" onclick="return {{c_skip}} > 0;"
                                        class="w-full px-2 py-2 rounded-xl border-2 text-center transition-all duration-200
                                               {{#c_skip}}border-yellow-200 bg-yellow-50 hover:bg-yellow-100 hover:border-yellow-400 cursor-pointer{{/c_skip}}
                                               {{^c_skip}}border-gray-200 bg-gray-50 opacity-50 cursor-not-allowed{{/c_skip}}">
                                    <span class="block text-xs font-bold {{#c_skip}}text-yellow-700{{/c_skip}}{{^c_skip}}text-gray-400{{/c_skip}}"><i class="fas fa-forward-step"></i> Saltear</span>
                                    <span class="block text-[10px] {{#c_skip}}text-yellow-500{{/c_skip}}{{^c_skip}}text-gray-400{{/c_skip}}">({{c_skip}})</span>
                                </button>
                            </form>
                            <form action="/trampitas/usar" method="POST" class="flex-1 min-w-0">
                                <input type="hidden" name="partida_id" value="{{partida.id}}">
                                <input type="hidden" name="tipo" value="congelar_tiempo">
                                <button type="submit" onclick="return {{c_freeze}} > 0;"
                                        class="w-full px-2 py-2 rounded-xl border-2 text-center transition-all duration-200
                                               {{#c_freeze}}border-cyan-200 bg-cyan-50 hover:bg-cyan-100 hover:border-cyan-400 cursor-pointer{{/c_freeze}}
                                               {{^c_freeze}}border-gray-200 bg-gray-50 opacity-50 cursor-not-allowed{{/c_freeze}}">
                                    <span class="block text-xs font-bold {{#c_freeze}}text-cyan-700{{/c_freeze}}{{^c_freeze}}text-gray-400{{/c_freeze}}"><i class="fas fa-snowflake"></i> +15s</span>
                                    <span class="block text-[10px] {{#c_freeze}}text-cyan-500{{/c_freeze}}{{^c_freeze}}text-gray-400{{/c_freeze}}">({{c_freeze}})</span>
                                </button>
                            </form>
                        </div>
                    </div>
                    {{/stockTrampitas}}
                </div>
            </div>
        </div>
    </div>
    {{>footer}}
</div>

<div id="report-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40">
    <div class="bg-white rounded-2xl shadow-xl p-6 w-full max-w-sm mx-4">
        <h3 class="text-lg font-bold text-gray-800 mb-2">Reportar pregunta</h3>
        <p class="text-sm text-gray-500 mb-4">Describí por qué considerás que esta pregunta es inválida:</p>
        <form action="/juego/reportar" method="POST">
            <input type="hidden" name="pregunta_id" value="{{pregunta.id}}">
            <textarea name="motivo" rows="4" required
                      class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 placeholder-gray-400 transition-all duration-200 mb-4"
                      placeholder="Escribí el motivo del reporte..."></textarea>
            <div class="flex gap-3 justify-end">
                <button type="button" onclick="document.getElementById('report-modal').classList.add('hidden')"
                        class="px-4 py-2 rounded-xl border-2 border-gray-300 text-gray-600 font-medium hover:bg-gray-100 transition-all duration-200 cursor-pointer">
                    Cancelar
                </button>
                <button type="submit"
                        class="px-4 py-2 rounded-xl bg-red-500 text-white font-semibold hover:bg-red-600 transition-all duration-200 cursor-pointer shadow-md">
                    Enviar reporte
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    (function() {
        var segundos = {{tiempo_restante}};
        var span = document.getElementById('timer-segundos');
        var timerEl = document.getElementById('timer');

        if (!span || !timerEl) return;

        var intervalo = setInterval(function() {
            segundos--;
            span.textContent = segundos;

            if (segundos <= 10) {
                timerEl.classList.remove('text-gray-600');
                timerEl.classList.add('text-red-500');
            }

            if (segundos <= 0) {
                clearInterval(intervalo);
                window.location.href = '/juego/tiempo';
            }
        }, 1000);
    })();
</script>
