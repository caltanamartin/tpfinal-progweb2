{{>header}}
<div class="min-h-screen flex flex-col pt-14">
    <div class="flex-1 flex items-center justify-center p-4">
        <div class="w-full max-w-lg">
            <div class="flex justify-between items-center mb-4">
                <span id="timer" class="text-lg font-bold text-gray-600 flex items-center gap-1">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <span id="timer-segundos">{{tiempo_restante}}</span>s
                </span>
                <span class="text-lg font-bold text-[#00b582]">
                    Puntaje: {{partida.puntaje}}
                </span>
            </div>

            <div class="rounded-2xl shadow-lg overflow-hidden"
                 style="border-top: 6px solid {{pregunta.categoria_color}};">

                <div class="bg-white px-6 py-3 flex items-center gap-2"
                     style="background-color: {{pregunta.categoria_color}}10;">
                    <span class="text-xs font-semibold uppercase tracking-wide"
                          style="color: {{pregunta.categoria_color}};">
                        {{pregunta.categoria_nombre}}
                    </span>
                    {{#pregunta.esNeutra}}
                    <span class="text-xs px-2 py-0.5 rounded-full bg-gray-200 text-gray-500">Periodo de prueba{{#pregunta.respuestas_global}} ({{pregunta.respuestas_global}}/10){{/pregunta.respuestas_global}}</span>
                    {{/pregunta.esNeutra}}
                    {{^pregunta.esNeutra}}
                    <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 text-gray-600">{{pregunta.dificultad_label}}</span>
                    {{/pregunta.esNeutra}}
                </div>

                <div class="bg-white px-6 py-6">
                    <h2 class="text-xl font-bold text-gray-800 mb-6 leading-relaxed">
                        {{pregunta.pregunta}}
                    </h2>

                    <form action="/juego/responder" method="POST" id="form-respuesta">
                        <input type="hidden" name="partida_id" value="{{partida.id}}">
                        <div class="space-y-3">
                            {{#pregunta.opciones}}
                            <button type="submit" name="respuesta" value="{{letra}}"
                                    class="w-full text-left px-5 py-4 rounded-xl border-2 border-gray-200
                                           hover:border-[#00b582] hover:bg-[#00b582] hover:text-white
                                           hover:shadow-md transition-all duration-200
                                           font-medium text-gray-700 cursor-pointer flex items-center gap-3
                                           focus:outline-none focus:ring-2 focus:ring-[#00b582] focus:ring-offset-2">
                                <span class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center
                                             font-bold text-sm text-gray-500 flex-shrink-0
                                             group-hover:bg-white/20 group-hover:text-white">
                                    {{letra}}
                                </span>
                                <span>{{texto}}</span>
                            </button>
                            {{/pregunta.opciones}}
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
    {{>footer}}
</div>

<script>
    (function() {
        var segundos = {{tiempo_restante}};
        var span = document.getElementById('timer-segundos');
        var timerEl = document.getElementById('timer');

        if (!span || !timerEl) return;

        var intervalo = setInterval(function() {
            segundos--;
            span.textContent = segundos;

            if (segundos <= 10) {
                timerEl.classList.remove('text-gray-600');
                timerEl.classList.add('text-red-500');
            }

            if (segundos <= 0) {
                clearInterval(intervalo);
                window.location.href = '/juego/tiempo';
            }
        }, 1000);
    })();
</script>
