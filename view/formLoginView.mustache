{{>header}}
<div class="h-screen overflow-hidden flex flex-col bg-gray-50">
    <div class="flex-1 flex items-center justify-center px-4">
        <div class="w-full max-w-sm">
            <div class="bg-white rounded-2xl p-8 border border-gray-200 shadow-sm">
                <div class="flex justify-center gap-3 mb-6">
                    <div class="w-10 h-10 rounded-full" style="background: #f74114;"></div>
                    <div class="w-10 h-10 rounded-full" style="background: #007ca6;"></div>
                    <div class="w-10 h-10 rounded-full" style="background: #00b582;"></div>
                    <div class="w-10 h-10 rounded-full" style="background: #ffb042;"></div>
                </div>
                <h2 class="text-2xl font-bold text-center text-gray-800 mb-1">Iniciar sesión</h2>
                <p class="text-sm text-gray-400 text-center mb-8">Ingresá tus credenciales</p>
                <form method='POST'>
                    <div class="mb-5">
                        <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">Email</label>
                        <input type="email" id="email" name="email" placeholder="tu@email.com"
                               class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 placeholder-gray-400 transition-all duration-200">
                    </div>
                    <div class="mb-6">
                        <label for="password" class="block text-sm font-medium text-gray-700 mb-1.5">Contraseña</label>
                        <input type="password" id="password" name="password" placeholder="••••••••"
                               class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 placeholder-gray-400 transition-all duration-200">
                    </div>
                    <button type="submit"
                            class="w-full bg-[#00b582] font-bold text-lg px-10 py-3 rounded-full text-white transition-all duration-300 cursor-pointer shadow-md hover:shadow-lg">
                        Ingresar
                    </button>
                </form>
                <p class="text-center text-sm text-gray-400 mt-6">
                    ¿Todavía no tenés cuenta?
                    <a href="/registro" class="text-[#007ca6] font-medium transition-colors duration-200 cursor-pointer"">Registrate</a>
                </p>
            </div>
        </div>
    </div>
    {{>footer}}
</div>
