{{>header}}
<div class="min-h-screen flex flex-col bg-gray-50 pt-16">
    <div class="flex-1 flex items-start justify-center px-4 py-8">
        <div class="w-full max-w-md">
            <div class="bg-white rounded-2xl p-8 border border-gray-200 shadow-sm">
                <div class="flex justify-center gap-3 mb-6">
                    <div class="w-10 h-10 rounded-full" style="background: #f74114;"></div>
                    <div class="w-10 h-10 rounded-full" style="background: #007ca6;"></div>
                    <div class="w-10 h-10 rounded-full" style="background: #00b582;"></div>
                    <div class="w-10 h-10 rounded-full" style="background: #ffb042;"></div>
                </div>
                <h2 class="text-2xl font-bold text-center text-gray-800 mb-1">Crear nueva pregunta</h2>
                <p class="text-sm text-gray-400 text-center mb-8">Completá todos los campos para agregar una pregunta</p>

                {{#error}}
                <p class="text-sm text-red-600 bg-red-50 border border-red-200 rounded-xl px-4 py-3 mb-4">{{error}}</p>
                {{/error}}

                <form method="POST" action="/pregunta/guardar">
                    <div class="mb-4">
                        <label for="categoria_id" class="block text-sm font-medium text-gray-700 mb-1.5">Categoría</label>
                        <select id="categoria_id" name="categoria_id" required
                                class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 transition-all duration-200">
                            <option value="">Seleccioná una categoría</option>
                            {{#categorias}}
                            <option value="{{id}}">{{nombre}}</option>
                            {{/categorias}}
                        </select>
                    </div>
                    <div class="mb-4">
                        <label for="pregunta" class="block text-sm font-medium text-gray-700 mb-1.5">Pregunta</label>
                        <textarea id="pregunta" name="pregunta" rows="3" placeholder="Escribí la pregunta"
                                  class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 placeholder-gray-400 transition-all duration-200" required></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="opcion_a" class="block text-sm font-medium text-gray-700 mb-1.5">Opción A</label>
                        <input type="text" id="opcion_a" name="opcion_a" placeholder="Texto de la opción A"
                               class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 placeholder-gray-400 transition-all duration-200" required>
                    </div>
                    <div class="mb-3">
                        <label for="opcion_b" class="block text-sm font-medium text-gray-700 mb-1.5">Opción B</label>
                        <input type="text" id="opcion_b" name="opcion_b" placeholder="Texto de la opción B"
                               class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 placeholder-gray-400 transition-all duration-200" required>
                    </div>
                    <div class="mb-3">
                        <label for="opcion_c" class="block text-sm font-medium text-gray-700 mb-1.5">Opción C</label>
                        <input type="text" id="opcion_c" name="opcion_c" placeholder="Texto de la opción C"
                               class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 placeholder-gray-400 transition-all duration-200" required>
                    </div>
                    <div class="mb-3">
                        <label for="opcion_d" class="block text-sm font-medium text-gray-700 mb-1.5">Opción D</label>
                        <input type="text" id="opcion_d" name="opcion_d" placeholder="Texto de la opción D"
                               class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 placeholder-gray-400 transition-all duration-200" required>
                    </div>
                    <div class="mb-6">
                        <label for="respuesta_correcta" class="block text-sm font-medium text-gray-700 mb-1.5">Respuesta correcta</label>
                        <select id="respuesta_correcta" name="respuesta_correcta" required
                                class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 transition-all duration-200">
                            <option value="">Seleccioná la respuesta correcta</option>
                            <option value="A">A</option>
                            <option value="B">B</option>
                            <option value="C">C</option>
                            <option value="D">D</option>
                        </select>
                    </div>
                    <button type="submit"
                            class="w-full bg-[#00b582] font-bold text-lg px-10 py-3 rounded-full text-white transition-all duration-300 cursor-pointer shadow-md hover:shadow-lg">
                        Guardar pregunta
                    </button>
                </form>
                <div class="mt-6 text-center">
                    <a href="/" class="text-sm font-medium text-gray-400 hover:text-gray-600 transition-colors">Cancelar</a>
                </div>
            </div>
        </div>
    </div>
    {{>footer}}
</div>
