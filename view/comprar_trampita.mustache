{{>header}}
<div class="min-h-screen flex flex-col pt-14">
    <div class="flex-1 px-4 py-8 max-w-lg mx-auto w-full">
        {{#esComprar}}
        <a href="/trampitas" class="inline-block text-sm text-gray-400 hover:text-gray-600 transition-colors mb-6">&larr; Volver a la tienda</a>

        <h1 class="text-2xl font-bold text-gray-800 mb-2">Comprar trampita</h1>
        <p class="text-gray-500 text-sm mb-6">Completá los datos de tu tarjeta para simular el pago.</p>

        <div class="bg-white rounded-2xl p-6 border border-gray-200 shadow-sm mb-6">
            <div class="flex items-center gap-3 mb-4 pb-4 border-b border-gray-100">
                <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center text-lg font-bold text-gray-600">
                    {{#tipoInfo.es5050}}½{{/tipoInfo.es5050}}
                    {{#tipoInfo.esSkip}}⏭{{/tipoInfo.esSkip}}
                    {{#tipoInfo.esFreeze}}❄{{/tipoInfo.esFreeze}}
                </div>
                <div>
                    <p class="font-bold text-gray-800">{{tipoInfo.nombre}}</p>
                    <p class="text-xs text-gray-500">{{tipoInfo.descripcion}}</p>
                </div>
                <span class="ml-auto text-lg font-bold text-[#00b582]">USD {{tipoInfo.precio}},00</span>
            </div>
        </div>

        {{#error}}
        <p class="text-sm text-red-600 bg-red-50 border border-red-200 rounded-xl px-4 py-3 mb-4">{{error}}</p>
        {{/error}}

        <form action="/trampitas/comprar" method="POST" class="bg-white rounded-2xl p-6 border border-gray-200 shadow-sm">
            <input type="hidden" name="tipo" value="{{tipoInfo.tipo}}">

            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 mb-1">Nombre del titular</label>
                <input type="text" name="card_name" required
                       class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 placeholder-gray-400 transition-all duration-200"
                       placeholder="Como figura en la tarjeta">
            </div>

            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 mb-1">Número de tarjeta</label>
                <input type="text" name="card_number" inputmode="numeric" maxlength="19" required
                       class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 placeholder-gray-400 transition-all duration-200 font-mono"
                       placeholder="1234 5678 9012 3456"
                       oninput="this.value = this.value.replace(/\D/g,'').replace(/(.{4})/g,'$1 ').trim()">
            </div>

            <div class="flex gap-4 mb-4">
                <div class="flex-1">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Fecha de expiración</label>
                    <input type="text" name="card_expiry" inputmode="numeric" maxlength="5" required
                           class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 placeholder-gray-400 transition-all duration-200 font-mono"
                           placeholder="MM/AA"
                           oninput="this.value = this.value.replace(/\D/g,'').replace(/^(\d{2})/,'$1/').trim().substring(0,5)">
                </div>
                <div class="w-24">
                    <label class="block text-sm font-medium text-gray-700 mb-1">CVV</label>
                    <input type="text" name="card_cvv" inputmode="numeric" maxlength="3" required
                           class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 placeholder-gray-400 transition-all duration-200 font-mono"
                           placeholder="123"
                           oninput="this.value = this.value.replace(/\D/g,'').substring(0,3)">
                </div>
            </div>

            <button type="submit"
                    class="w-full bg-[#00b582] font-bold text-lg px-8 py-3 rounded-full text-white transition-all duration-300 cursor-pointer shadow-md hover:shadow-lg hover:scale-[1.02] mt-2">
                Pagar USD {{tipoInfo.precio}},00
            </button>

        </form>
        {{/esComprar}}

        {{^esComprar}}
        <h1 class="text-2xl font-bold text-gray-800 mb-1">Tienda de trampitas</h1>
        <p class="text-gray-500 text-sm mb-6">Potenciá tu juego con trampitas que te ayudan a ganar.</p>

        {{#exito}}
        <p class="text-sm text-green-600 bg-green-50 border border-green-200 rounded-xl px-4 py-3 mb-4">{{exito}}</p>
        {{/exito}}
        {{#error}}
        <p class="text-sm text-red-600 bg-red-50 border border-red-200 rounded-xl px-4 py-3 mb-4">{{error}}</p>
        {{/error}}

        {{#stock}}
        <div class="bg-white rounded-2xl p-4 border border-gray-200 shadow-sm mb-6">
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-3">Tu inventario</p>
            <div class="grid grid-cols-3 gap-2 text-center text-sm">
                <div class="bg-gray-50 rounded-xl p-3">
                    <span class="block text-lg font-bold text-gray-800">{{stock.c_5050}}</span>
                    <span class="text-xs text-gray-500">50/50</span>
                </div>
                <div class="bg-gray-50 rounded-xl p-3">
                    <span class="block text-lg font-bold text-gray-800">{{stock.c_skip}}</span>
                    <span class="text-xs text-gray-500">Saltear</span>
                </div>
                <div class="bg-gray-50 rounded-xl p-3">
                    <span class="block text-lg font-bold text-gray-800">{{stock.c_freeze}}</span>
                    <span class="text-xs text-gray-500">Congelar</span>
                </div>
            </div>
        </div>
        {{/stock}}

        <div class="space-y-4">
            {{#tipos}}
            <div class="bg-white rounded-2xl p-5 border border-gray-200 shadow-sm flex items-center gap-4">
                <div class="flex-1">
                    <h3 class="font-bold text-gray-800">{{nombre}}</h3>
                    <p class="text-sm text-gray-500">{{descripcion}}</p>
                </div>
                <div class="text-right">
                    <p class="text-lg font-bold text-[#00b582]">USD {{precio}},00</p>
                    <a href="/trampitas/comprar?tipo={{tipo}}"
                       class="inline-block mt-1 text-xs font-semibold bg-[#00b582] text-white px-4 py-1.5 rounded-full hover:bg-[#009d6f] transition-colors">
                        Comprar
                    </a>
                </div>
            </div>
            {{/tipos}}
        </div>

        <div class="mt-8 text-center">
            <a href="/" class="text-sm text-gray-400 hover:text-gray-600 transition-colors">Volver al lobby</a>
        </div>
        {{/esComprar}}
    </div>
    {{>footer}}
</div>
