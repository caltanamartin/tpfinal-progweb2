{{>header}}
<style>
    @keyframes curtainSlide {
        0%   { transform: scaleY(0); }
        100% { transform: scaleY(1); }
    }
    @keyframes curtainText {
        0%   { opacity: 0; transform: scale(0.6); }
        100% { opacity: 1; transform: scale(1); }
    }
    @keyframes curtainFade {
        0%, 70% { opacity: 1; }
        100%   { opacity: 0; }
    }
    .anim-curtain-overlay {
        animation: curtainFade 1.5s ease-in forwards;
    }
    .anim-curtain-slide {
        transform-origin: top center;
        animation: curtainSlide 0.35s ease-out forwards;
    }
    .anim-curtain-text {
        opacity: 0;
        animation: curtainText 0.3s ease-out 0.35s forwards;
    }
</style>

<div class="min-h-screen flex flex-col bg-gray-50 pt-16">
    <div class="flex-1 flex items-center justify-center px-4">
        <div class="w-full max-w-md">
                <div class="flex justify-end items-center mb-4">
                    <span class="text-lg font-bold text-[#00b582]">
                        Puntaje: {{partida.puntaje}} pts
                    </span>
                </div>
            <div class="bg-white rounded-2xl p-8 border border-gray-200 shadow-sm relative overflow-hidden">
                {{#respuestaCorrecta}}
                <div class="anim-curtain-overlay absolute inset-0 z-10 rounded-2xl pointer-events-none overflow-hidden">
                    <div class="anim-curtain-slide absolute inset-0 bg-green-500"></div>
                    <div class="anim-curtain-text absolute inset-0 flex items-center justify-center">
                        <div class="text-center text-white">
                            <div class="text-5xl mb-2">✓</div>
                            <div class="text-2xl font-bold">¡Respuesta correcta! +1</div>
                        </div>
                    </div>
                </div>
                {{/respuestaCorrecta}}
                <div class="flex justify-center gap-3 mb-6">
                    <div class="w-10 h-10 rounded-full" style="background: #f74114;"></div>
                    <div class="w-10 h-10 rounded-full" style="background: #007ca6;"></div>
                    <div class="w-10 h-10 rounded-full" style="background: #00b582;"></div>
                    <div class="w-10 h-10 rounded-full" style="background: #ffb042;"></div>
                </div>
                <h2 class="text-2xl font-bold text-center text-gray-800 mb-1">Elegí una categoría</h2>
                <p class="text-sm text-gray-400 text-center mb-8">Seleccioná de qué tema querés la próxima pregunta</p>

                {{#error}}
                <p class="text-sm text-red-600 bg-red-50 border border-red-200 rounded-xl px-4 py-3 mb-4">{{error}}</p>
                {{/error}}

                <form method="POST" class="space-y-3">
                    <input type="hidden" name="id" value="{{partida.id}}">
                    {{#categorias}}
                    <button type="submit" name="categoria_id" value="{{id}}"
                            class="w-full text-left px-5 py-4 rounded-xl border-2 font-semibold text-white
                                   transition-all duration-200 cursor-pointer shadow-sm hover:shadow-md hover:scale-[1.02]"
                            style="background-color: {{color}}; border-color: {{color}};">
                        {{nombre}}
                    </button>
                    {{/categorias}}
                </form>

                <div class="mt-6 text-center">
                    <a href="/" class="text-sm font-medium text-gray-400 hover:text-gray-600 transition-colors">Cancelar</a>
                </div>
            </div>
        </div>
    </div>
    {{>footer}}
</div>
