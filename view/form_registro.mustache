{{>header}}
<div class="min-h-screen flex flex-col bg-gray-50 pt-16">
    <div class="flex-1 flex items-center justify-center px-4 py-8">
        <div class="w-full max-w-md">
            <div class="bg-white rounded-2xl p-8 border border-gray-200 shadow-sm">
                <div class="flex justify-center gap-3 mb-6">
                    <div class="w-10 h-10 rounded-full" style="background: #f74114;"></div>
                    <div class="w-10 h-10 rounded-full" style="background: #007ca6;"></div>
                    <div class="w-10 h-10 rounded-full" style="background: #00b582;"></div>
                    <div class="w-10 h-10 rounded-full" style="background: #ffb042;"></div>
                </div>
                <h2 class="text-2xl font-bold text-center text-gray-800 mb-1">Creá tu cuenta</h2>
                <p class="text-sm text-gray-400 text-center mb-8">Completá los datos para registrarte</p>
                {{#error}}
                <p class="text-sm text-red-600 bg-red-50 border border-red-200 rounded-xl px-4 py-3 mb-4">{{error}}</p>
                {{/error}}
                <form method='POST' enctype="multipart/form-data">
                    <div class="mb-4">
                        <label for="nombre" class="block text-sm font-medium text-gray-700 mb-1.5">Nombre completo</label>
                        <input type="text" id="nombre" name="nombre" placeholder="Tu nombre"
                               class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 placeholder-gray-400 transition-all duration-200" required>
                    </div>
                    <div class="mb-4">
                        <label for="anio_nacimiento" class="block text-sm font-medium text-gray-700 mb-1.5">Fecha de nacimiento</label>
                        <input type="date" id="anio_nacimiento" name="anio_nacimiento"
                               class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 transition-all duration-200" required>
                    </div>
                    <div class="mb-4">
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">Sexo</label>
                        <div class="flex gap-4">
                            <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                                <input type="radio" name="sexo" value="Masculino" class="accent-[#00b582]">
                                Masculino
                            </label>
                            <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                                <input type="radio" name="sexo" value="Femenino" class="accent-[#00b582]">
                                Femenino
                            </label>
                            <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                                <input type="radio" name="sexo" value="Prefiero no cargarlo" checked class="accent-[#00b582]">
                                Prefiero no cargarlo
                            </label>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">Ubicación</label>
                        <p class="text-xs text-gray-400 mb-2">Hacé clic en el mapa para marcar tu ubicación</p>
                        <div id="mapa-registro" class="w-full rounded-xl overflow-hidden border border-gray-200" style="height: 220px;"></div>
                        <input type="text" id="pais" name="pais" placeholder="País"
                               class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 bg-gray-50 transition-all duration-200 mt-3" readonly required>
                        <input type="text" id="ciudad" name="ciudad" placeholder="Ciudad"
                               class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 bg-gray-50 transition-all duration-200 mt-2" readonly required>
                    </div>
                    <div class="mb-4">
                        <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">Email</label>
                        <input type="email" id="email" name="email" placeholder="tu@email.com"
                               class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 placeholder-gray-400 transition-all duration-200" required>
                    </div>
                    <div class="mb-4">
                        <label for="username" class="block text-sm font-medium text-gray-700 mb-1.5">Nombre de usuario</label>
                        <input type="text" id="username" name="username" placeholder="Ej: vikingo123"
                               class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 placeholder-gray-400 transition-all duration-200" required>
                    </div>
                    <div class="mb-4">
                        <label for="password" class="block text-sm font-medium text-gray-700 mb-1.5">Contraseña</label>
                        <input type="password" id="password" name="password" placeholder="••••••••"
                               class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 placeholder-gray-400 transition-all duration-200" required>
                    </div>
                    <div class="mb-4">
                        <label for="password_confirm" class="block text-sm font-medium text-gray-700 mb-1.5">Repetir contraseña</label>
                        <input type="password" id="password_confirm" name="password_confirm" placeholder="••••••••"
                               class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 placeholder-gray-400 transition-all duration-200" required>
                    </div>
                    <div class="mb-6">
                        <label for="foto_perfil" class="block text-sm font-medium text-gray-700 mb-1.5">Foto de perfil</label>
                        <input type="file" id="foto_perfil" name="foto_perfil" accept="image/*"
                               class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 transition-all duration-200 cursor-pointer">
                    </div>
                    <button type="submit"
                            class="w-full bg-[#00b582] font-bold text-lg px-10 py-3 rounded-full text-white transition-all duration-300 cursor-pointer shadow-md hover:shadow-lg">
                        Registrarse
                    </button>
                </form>
                <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
                <script>
                document.addEventListener('DOMContentLoaded', function() {
                    var map = L.map('mapa-registro', { zoomControl: false }).setView([-34.6, -58.4], 3);
                    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

                    var marker = null;

                    map.on('click', function(e) {
                        if (marker) marker.setLatLng(e.latlng);
                        else marker = L.marker(e.latlng).addTo(map);

                        var url = 'https://nominatim.openstreetmap.org/reverse?lat=' + e.latlng.lat + '&lon=' + e.latlng.lng + '&format=json';
                        var xhr = new XMLHttpRequest();
                        xhr.open('GET', url, true);
                        xhr.send();
                        xhr.onload = function() {
                            if (xhr.status === 200) {
                                var data = JSON.parse(xhr.responseText);
                                var addr = data.address || {};
                                document.getElementById('pais').value = addr.country || '';
                                document.getElementById('ciudad').value = addr.city || addr.town || addr.village || addr.municipality || '';
                            }
                        };
                    });
                });
                </script>
                <p class="text-center text-sm text-gray-400 mt-6">
                    ¿Ya tenés cuenta?
                    <a href="/auth/login" class="font-medium text-[#007ca6] transition-colors duration-200 cursor-pointer">Iniciá sesión</a>
                </p>
            </div>
        </div>
    </div>
    {{>footer}}
</div>
