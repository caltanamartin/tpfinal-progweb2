{{>header}}
<div class="min-h-screen flex flex-col pt-16">
    <div class="flex-1 flex items-start justify-center px-4 py-8">
        <div class="w-full max-w-md">
            <div class="bg-white rounded-2xl p-8 border border-gray-200 shadow-sm">
                <h2 class="text-2xl font-bold text-center text-gray-800 mb-1">Editar pregunta</h2>
                <p class="text-sm text-gray-400 text-center mb-8">Modificá los campos que quieras</p>

                {{#error}}
                <p class="text-sm text-red-600 bg-red-50 border border-red-200 rounded-xl px-4 py-3 mb-4">{{error}}</p>
                {{/error}}

                <form method="POST" action="/editor/preguntas/guardar">
                    <input type="hidden" name="id" value="{{pregunta.id}}">

                    <div class="mb-4">
                        <label for="categoria_id" class="block text-sm font-medium text-gray-700 mb-1.5">Categoría</label>
                        <select id="categoria_id" name="categoria_id" required
                                class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 transition-all duration-200">
                            {{#categorias}}
                            <option value="{{id}}" {{#selected}}selected{{/selected}}>{{nombre}}</option>
                            {{/categorias}}
                        </select>
                    </div>
                    <div class="mb-4">
                        <label for="pregunta" class="block text-sm font-medium text-gray-700 mb-1.5">Pregunta</label>
                        <textarea id="pregunta" name="pregunta" rows="3"
                                  class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 placeholder-gray-400 transition-all duration-200"
                                  required>{{pregunta.pregunta}}</textarea>
                    </div>
                    <div class="mb-3">
                        <label for="opcion_a" class="block text-sm font-medium text-gray-700 mb-1.5">Opción A</label>
                        <input type="text" id="opcion_a" name="opcion_a" value="{{pregunta.opcion_a}}"
                               class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 placeholder-gray-400 transition-all duration-200" required>
                    </div>
                    <div class="mb-3">
                        <label for="opcion_b" class="block text-sm font-medium text-gray-700 mb-1.5">Opción B</label>
                        <input type="text" id="opcion_b" name="opcion_b" value="{{pregunta.opcion_b}}"
                               class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 placeholder-gray-400 transition-all duration-200" required>
                    </div>
                    <div class="mb-3">
                        <label for="opcion_c" class="block text-sm font-medium text-gray-700 mb-1.5">Opción C</label>
                        <input type="text" id="opcion_c" name="opcion_c" value="{{pregunta.opcion_c}}"
                               class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 placeholder-gray-400 transition-all duration-200" required>
                    </div>
                    <div class="mb-3">
                        <label for="opcion_d" class="block text-sm font-medium text-gray-700 mb-1.5">Opción D</label>
                        <input type="text" id="opcion_d" name="opcion_d" value="{{pregunta.opcion_d}}"
                               class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 placeholder-gray-400 transition-all duration-200" required>
                    </div>
                    <div class="mb-6">
                        <label for="respuesta_correcta" class="block text-sm font-medium text-gray-700 mb-1.5">Respuesta correcta</label>
                        <select id="respuesta_correcta" name="respuesta_correcta" required
                                class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 transition-all duration-200">
                            <option value="A" {{#pregunta.esA}}selected{{/pregunta.esA}}>A</option>
                            <option value="B" {{#pregunta.esB}}selected{{/pregunta.esB}}>B</option>
                            <option value="C" {{#pregunta.esC}}selected{{/pregunta.esC}}>C</option>
                            <option value="D" {{#pregunta.esD}}selected{{/pregunta.esD}}>D</option>
                        </select>
                    </div>
                    <button type="submit"
                            class="w-full bg-[#00b582] font-bold text-lg px-10 py-3 rounded-full text-white transition-all duration-300 cursor-pointer shadow-md hover:shadow-lg">
                        Guardar cambios
                    </button>
                </form>
                <div class="mt-6 text-center">
                    <a href="{{backUrl}}" class="text-sm font-medium text-gray-400 hover:text-gray-600 transition-colors">Cancelar</a>
                </div>
            </div>
        </div>
    </div>
    {{>footer}}
</div>
