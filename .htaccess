RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

RewriteRule ^login$              index.php?controller=auth&method=verLogin [L,QSA]
RewriteRule ^registro$           index.php?controller=auth&method=verRegistro [L,QSA]
RewriteRule ^logout$             index.php?controller=auth&method=logout [L,QSA]
RewriteRule ^perfil/(\d+)$       index.php?controller=perfil&method=verPublico&id=$1 [L,QSA]
RewriteRule ^perfil$             index.php?controller=perfil&method=ver [L,QSA]
RewriteRule ^perfil/editar$      index.php?controller=perfil&method=editarPerfil [L,QSA]

RewriteRule ^vikingo/alta$       index.php?controller=vikingo&method=alta [L,QSA]
RewriteRule ^vikingo/procesarAlta$ index.php?controller=vikingo&method=procesarAlta [L,QSA]
RewriteRule ^vikingo/editar$     index.php?controller=vikingo&method=editar [L,QSA]
RewriteRule ^vikingo/eliminar$   index.php?controller=vikingo&method=eliminar [L,QSA]
RewriteRule ^vikingo/procesarEditar$ index.php?controller=vikingo&method=procesarEditar [L,QSA]
RewriteRule ^vikingo$            index.php?controller=vikingo&method=ver [L,QSA]

RewriteRule ^juego/nueva$        index.php?controller=juego&method=nuevaPartida [L,QSA]
RewriteRule ^juego/categoria$    index.php?controller=juego&method=categoria [L,QSA]
RewriteRule ^juego/reportar$     index.php?controller=juego&method=reportar [L,QSA]
RewriteRule ^juego/responder$    index.php?controller=juego&method=responder [L,QSA]
RewriteRule ^juego/tiempo$       index.php?controller=juego&method=tiempoAgotado [L,QSA]
RewriteRule ^juego/resultado$    index.php?controller=juego&method=resultado [L,QSA]
RewriteRule ^juego$              index.php?controller=juego&method=jugar [L,QSA]

RewriteRule ^pregunta/crear$     index.php?controller=pregunta&method=crear [L,QSA]
RewriteRule ^pregunta/guardar$   index.php?controller=pregunta&method=guardar [L,QSA]

RewriteRule ^editor$                      index.php?controller=editor&method=index [L,QSA]
RewriteRule ^editor/preguntas$            index.php?controller=editor&method=preguntas [L,QSA]
RewriteRule ^editor/preguntas/editar/(\d+)$ index.php?controller=editor&method=editar&id=$1 [L,QSA]
RewriteRule ^editor/preguntas/guardar$    index.php?controller=editor&method=guardar [L,QSA]
RewriteRule ^editor/preguntas/eliminar$   index.php?controller=editor&method=eliminar [L,QSA]
RewriteRule ^editor/preguntas/activar$    index.php?controller=editor&method=activar [L,QSA]
RewriteRule ^editor/reportes$             index.php?controller=editor&method=reportes [L,QSA]
RewriteRule ^editor/reportes/aprobar$     index.php?controller=editor&method=aprobarReporte [L,QSA]
RewriteRule ^editor/reportes/rechazar$    index.php?controller=editor&method=rechazarReporte [L,QSA]
RewriteRule ^editor/pendientes$           index.php?controller=editor&method=pendientes [L,QSA]
RewriteRule ^editor/pendientes/aprobar$   index.php?controller=editor&method=aprobarPendiente [L,QSA]
RewriteRule ^editor/pendientes/rechazar$  index.php?controller=editor&method=rechazarPendiente [L,QSA]

RewriteRule ^trampitas$                   index.php?controller=trampita&method=index [L,QSA]
RewriteRule ^trampitas/comprar$           index.php?controller=trampita&method=comprar [L,QSA]
RewriteRule ^trampitas/usar$              index.php?controller=trampita&method=usar [L,QSA]
RewriteRule ^admin/trampitas$             index.php?controller=trampita&method=adminListar [L,QSA]

RewriteRule ^admin$              index.php?controller=admin&method=index [L,QSA]

RewriteRule ^ranking$            index.php?controller=ranking&method=ver [L,QSA]
RewriteRule ^verificar/(.+)$     index.php?controller=auth&method=verificar&token=$1 [L,QSA]

RewriteRule ^$                   index.php?controller=home&method=ver [L,QSA]
